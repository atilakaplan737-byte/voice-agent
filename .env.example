# ──────────────────────────────────────────────
#  Server
# ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ──────────────────────────────────────────────
#  Branche (Vertical) dieses Deployments.
#  Wählt Config aus verticals/<id>.json → Brand, Kategorien, Felder, Prompt.
#  Verfügbar: arzt | physio | tierarzt   (neue Branche = neue JSON-Datei)
# ──────────────────────────────────────────────
VERTICAL=arzt

# ──────────────────────────────────────────────
#  Supabase
#  Projekt anlegen: https://supabase.com → New Project
#  Werte unter: Project Settings → API
# ──────────────────────────────────────────────
SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
# SERVICE-ROLE-Key (NUR serverseitig! niemals ins Frontend)
SUPABASE_SERVICE_ROLE_KEY=DEIN_SERVICE_ROLE_KEY

# ──────────────────────────────────────────────
#  Vapi Webhook-Schutz
#  In Vapi unter Assistant → Server → "Secret" denselben Wert setzen.
#  Vapi sendet ihn dann als Header  x-vapi-secret.
# ──────────────────────────────────────────────
VAPI_WEBHOOK_SECRET=ein-langes-zufaelliges-geheimnis

# ──────────────────────────────────────────────
#  Dashboard-Login (einfacher Schutz fürs Praxis-Personal, MVP)
#  Wird als Bearer-Token / x-dashboard-key erwartet.
# ──────────────────────────────────────────────
DASHBOARD_API_KEY=praxis-dashboard-passwort

# Branding (Name, Emoji, Farben) kommt aus verticals/<VERTICAL>.json –
# nichts weiter zu setzen.
